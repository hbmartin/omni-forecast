<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Serve + self-verify: each run appends to the forecast history that the
       verification loop later scores against arriving truth. -->
  <key>Label</key>
  <string>com.grounded-weather-forecast.predict</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/sh</string>
    <string>-lc</string>
    <string>cd __REPO__ &amp;&amp; grounded-weather-forecast predict --out __OUT_JSON__</string>
  </array>
  <key>StartInterval</key>
  <integer>600</integer>
  <key>StandardOutPath</key>
  <string>__LOG_DIR__/predict.log</string>
  <key>StandardErrorPath</key>
  <string>__LOG_DIR__/predict.log</string>
  <key>RunAtLoad</key>
  <true/>
</dict>
</plist>
